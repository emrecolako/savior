{
  "name": "genomic-report",
  "version": "0.1.0.1",
  "description": "Comprehensive personal genomic analysis — parse raw DNA data, cross-reference clinically significant variants, search latest research, generate actionable reports.",
  "keywords": ["genomics", "23andme", "ancestry", "snp", "pharmacogenomics", "gwas", "genetic-analysis"],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "genomic-report": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "db:stats": "tsx scripts/db-stats.ts",
    "db:validate": "tsx scripts/validate-db.ts",
    "db:fetch-pgc": "tsx scripts/fetch-pgc-gwas.ts",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:preview": "cd dashboard && npm run preview"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "docx": "^9.0.0",
    "dotenv": "^16.4.5",
    "gradient-string": "^3.0.0",
    "ora": "^8.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
